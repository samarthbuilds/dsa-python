"""
Problem: Find All Numbers Disappeared in an Array

Approach:
Use the input array itself to mark visited numbers.
For each number, mark the index corresponding to its value as negative.
After marking, the indices that remain positive indicate missing numbers.

Time Complexity: O(n)
Space Complexity: O(1)
"""

class Solution:
    def findDisappearedNumbers(self, nums: List[int]) -> List[int]:
        for i in range(len(nums)):
            index = abs(nums[i]) - 1
            nums[index] = -abs(nums[index])

        result = []

        for i in range(len(nums)):
            if nums[i] > 0:
                result.append(i + 1)

        return result
